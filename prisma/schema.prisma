generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String
  password       String
  itineraries    Itinerary[]
  following      Follow[]         @relation("UserFollowing")
  followers      Follow[]         @relation("UserFollowers")
  bucketList     BucketListItem[]
  createdAt      DateTime         @default(now())
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Itinerary {
  id           String           @id @default(cuid())
  title        String
  description  String?
  startDate    DateTime
  endDate      DateTime
  postType     String           @default("itinerary")
  audience     String           @default("family")
  visibility   String           @default("public")
  notes        String?
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  destinations Destination[]
  photos       Photo[]
  bucketedBy   BucketListItem[]
  createdAt    DateTime         @default(now())
}

model BucketListItem {
  id          String    @id @default(cuid())
  userId      String
  itineraryId String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@unique([userId, itineraryId])
}

model Destination {
  id          String     @id @default(cuid())
  name        String
  country     String?
  order       Int        @default(0)
  itineraryId String
  itinerary   Itinerary  @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  items       DestItem[]
}

// type: "activity" | "food_drink" | "hotel"
// mealType (food_drink only): "lunch" | "dinner" | "drinks" | null
model DestItem {
  id            String      @id @default(cuid())
  type          String
  mealType      String?
  name          String
  notes         String?
  rating        Int?
  link          String?
  groupIndex    Int         @default(0)
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}

model Photo {
  id          String    @id @default(cuid())
  url         String
  caption     String?
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
}
